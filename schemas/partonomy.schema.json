{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PartonomyEdge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "parent",
    "child",
    "rationale",
    "status",
    "confidence"
  ],
  "properties": {
    "parent": {
      "type": "string",
      "minLength": 1
    },
    "child": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "asserted",
        "reviewed",
        "disputed"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
