{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DependencyEdge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "from",
    "to",
    "relation_type",
    "necessity",
    "rationale",
    "failure_mode_if_absent",
    "evidence",
    "status",
    "confidence"
  ],
  "properties": {
    "from": {
      "type": "string",
      "minLength": 1
    },
    "to": {
      "type": "string",
      "minLength": 1
    },
    "relation_type": {
      "type": "string",
      "enum": [
        "requires_for_recognize",
        "requires_for_use",
        "requires_for_derive",
        "pedagogically_precedes"
      ]
    },
    "necessity": {
      "type": "string",
      "enum": [
        "necessary",
        "typical",
        "helpful"
      ]
    },
    "audience_profile": {
      "type": "string"
    },
    "subfield": {
      "type": "string"
    },
    "task_type": {
      "type": "string"
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "failure_mode_if_absent": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "source_ref"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "expert_claim",
              "textual_evidence",
              "corpus_evidence",
              "inferred"
            ]
          },
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "asserted",
        "reviewed",
        "disputed"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
