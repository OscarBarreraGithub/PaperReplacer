{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OverlayAnnotation",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overlay_type",
        "target_topic",
        "presumed_node",
        "audience_profile",
        "subfield",
        "rationale",
        "status",
        "confidence"
      ],
      "properties": {
        "overlay_type": {
          "type": "string",
          "enum": [
            "assumed_background"
          ]
        },
        "target_topic": {
          "type": "string",
          "minLength": 1
        },
        "presumed_node": {
          "type": "string",
          "minLength": 1
        },
        "audience_profile": {
          "type": "string",
          "minLength": 1
        },
        "subfield": {
          "type": "string",
          "minLength": 1
        },
        "artifact_type": {
          "type": "string"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "source_ref"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "expert_claim",
                  "textual_evidence",
                  "corpus_evidence",
                  "inferred"
                ]
              },
              "source_ref": {
                "type": "string",
                "minLength": 1
              },
              "note": {
                "type": "string"
              }
            }
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "asserted",
            "reviewed",
            "disputed"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "overlay_type",
        "researcher",
        "paper_count",
        "sample_papers",
        "role"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "overlay_type": {
          "type": "string",
          "enum": [
            "researcher_footprint"
          ]
        },
        "researcher": {
          "type": "string",
          "minLength": 1
        },
        "paper_count": {
          "type": "integer",
          "minimum": 1
        },
        "sample_papers": {
          "type": "array",
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "role": {
          "type": "string",
          "enum": [
            "introduced",
            "applied",
            "extended"
          ]
        }
      }
    }
  ]
}
